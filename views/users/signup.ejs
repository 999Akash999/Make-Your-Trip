<% layout("/layouts/boilerplate") %>
<div class="signup-form">
<div class="signup">
  <div class="logo">
    <i class="fa-solid fa-user fa-2xl" style="color:#6e5efc ;"></i>
  </div>
  <h4 class="create">Create your account</h4>
  <div class="form">
    <form action="/signup" method="POST" class="needs-validation" novalidation>
      <div class="name">
        <label for="username" class="form-label"></label>
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          placeholder= "Enter  your  username"
          required
          
        />
        <div class="valid-feedback">Looks good!</div>
      </div>
      <div class="name">
        <label for="email" class="form-label"></label>
        <input
          name="email"
          id="email"
          type="email"
          class="form-control"
          placeholder="Email"
          required
        />
        
      </div>
      <div class="name">
        <label for="password" class="form-label"></label>
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          placeholder="Password"
          required
        />
        
      </div>
      <button class="btn btn-success signup-btn mt-10">Sign Up</button>
      <p class="text-center or">or signup with</p>
      <div class="mt-3">
  <a href="/auth/google" class="btn btn-danger google-btn">
    Continue with Google
  </a>
</div>
    </form>
  </div>
</div>
</div>